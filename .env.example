# =============================================================================
# Obrigatório — Prisma liga-se ao Postgres do Supabase (a app usa isto)
# =============================================================================
# Project Settings → Database → Connection string → Direct connection (porta 5432)
#
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

DATABASE_URL=""

# =============================================================================
# Opcional — só precisas se integrares @supabase/supabase-js (Auth, Storage, etc.)
# Neste projeto o código actual NÃO lê estas variáveis; tudo passa pelo Prisma.
# =============================================================================
# Project Settings → API → Project URL e anon public
#
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
